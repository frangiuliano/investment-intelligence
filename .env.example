# App
PORT=3000
NODE_ENV=development

# Output language for analysis summaries and alerts (one locale per deploy).
# Allowed: en, es. Default: en. Affects Gemini summaries / Telegram labels in later issues.
APP_LOCALE=en

# PostgreSQL connection string used by NestJS
# In Docker Compose, host is the service name `postgres`
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/investment_intelligence

# Local (outside Docker) example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_intelligence

# Schema integration tests ONLY (never point this at the app/dev database).
# Database name must end in `_test`. Destructive: tests drop/recreate the public schema.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_intelligence_test

# --- Gemini API keys (use TWO separate Google AI Studio / Cloud projects) ---
# Do NOT reuse the same key for Finance and Reviewer: free tier is per project.

# Project B — news analysis at runtime (required by NestJS)
GEMINI_API_KEY_FINANCE=your_finance_gemini_api_key

# Project A — Reviewer Agent in GitHub Actions only (NOT required at NestJS boot)
# Configure as repo secret named GEMINI_API_KEY_REVIEWER when enabling automatic review:
#   Settings → Secrets and variables → Actions
# Also set variable AI_REVIEW_ENABLED=true to turn on .github/workflows/ai-review.yml
# (default / unset = off; use /rev in Cursor instead)
# GEMINI_API_KEY_REVIEWER=your_reviewer_gemini_api_key

# Delay between Gemini requests when analyzing news (milliseconds).
# Default 12000 helps stay under free-tier RPM (~5/min on some Flash models).
GEMINI_REQUEST_DELAY_MS=12000

# Gemini model for news analysis and briefs when LLM_PROVIDER=gemini
# (default: gemini-3.1-flash-lite).
# Prefer Flash-Lite for free tier. Avoid gemini-2.0-flash / gemini-2.5-flash for new keys.
GEMINI_MODEL=gemini-3.1-flash-lite

# Vendor-agnostic LLM provider for analysis + briefs (default: gemini).
# Only `gemini` is supported today; other values fail boot validation.
# LLM_PROVIDER=gemini

# Knowledge Pack root (repo-relative or absolute). Injected into analysis/brief prompts.
# KNOWLEDGE_ROOT=knowledge
# Soft cap for injected playbook/rubric markdown characters (default 12000).
# KNOWLEDGE_CONTEXT_MAX_CHARS=12000

# Max unanalyzed articles processed per analysis:once / analyzePending() run.
GEMINI_ANALYSIS_BATCH_SIZE=5

# Market data for historical daily OHLCV. Yahoo requires no API key.
MARKET_DATA_PROVIDER=yahoo
# External request timeout in milliseconds (1000-30000, default 10000).
MARKET_DATA_TIMEOUT_MS=10000

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Secret for POST /telegram/webhook (Telegram header X-Telegram-Bot-Api-Secret-Token).
# Empty = inbound webhook disabled. Required in production if you use /brief via webhook.
# Local fallback without HTTPS: npm run telegram:poll (after deleteWebhook).
# TELEGRAM_WEBHOOK_SECRET=pick_a_long_random_string

# Optional: comma-separated Telegram user ids allowed to run inbound commands.
# Prefer a private 1:1 chat with TELEGRAM_CHAT_ID > 0 (groups are rejected).
# TELEGRAM_ALLOWED_USER_IDS=123456789

# RSS feeds — comma-separated list of 1-2 feed URLs (required)
RSS_FEED_URLS=https://example.com/finance/rss

# Cron expression for the end-to-end pipeline (default: every 15 minutes)
COLLECTION_CRON_SCHEDULE=*/15 * * * *

# Hours within which matching stories collapse to one Telegram push (default: 24).
# Matching = shared ticker(s) + compatible event_type + similar title/summary.
# STORY_CLUSTER_WINDOW_HOURS=24

# Digesto Telegram (baja urgencia): cron separado del pipeline.
# Default diario 12:00 UTC. Para semanal: DIGEST_CRON_SCHEDULE=0 12 * * 1 + DIGEST_LOOKBACK_HOURS=168
# DIGEST_CRON_SCHEDULE=0 12 * * *
# DIGEST_LOOKBACK_HOURS=24

# Optional env fallback for relevance alerts when persisted watchlist is empty.
# Prefer POST/DELETE /watchlist. Empty/unset here and empty DB = any ticker counts.
# When either source is non-empty (DB wins if non-empty), at least one analyzed
# ticker must match the effective watchlist.
# WATCHLIST_TICKERS=AAPL,MSFT,GOOG

# Dashboard BFF → Nest shared secret (header x-dashboard-api-key).
# Empty = dashboard-facing routes (e.g. /reviews, /news/*, /assets/*) return 401.
# DASHBOARD_API_KEY=pick_a_long_random_string

# Monthly hypothesis review cron (default: 1st of month 12:00 UTC).
# That tick reviews the previous UTC calendar month (month close-out).
# REVIEW_CRON_SCHEDULE=0 12 1 * *

# Technical chart image sent after /brief when market data is attached (ADR 004).
# Rendered deterministically from OHLCV bars; failure never drops the brief text.
# TECHNICAL_CHART_ENABLED=true
# Comma-separated SMA windows drawn as overlays (e.g. 20 or 20,50).
# TECHNICAL_CHART_SMA_PERIODS=20
# Max daily bars rendered, 5-365 (default 90).
# TECHNICAL_CHART_MAX_BARS=90
