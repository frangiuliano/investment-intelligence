# App
PORT=3000
NODE_ENV=development

# PostgreSQL connection string used by NestJS
# In Docker Compose, host is the service name `postgres`
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/investment_intelligence

# Local (outside Docker) example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_intelligence

# Schema integration tests ONLY (never point this at the app/dev database).
# Database name must end in `_test`. Destructive: tests drop/recreate the public schema.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_intelligence_test

# --- Gemini API keys (use TWO separate Google AI Studio / Cloud projects) ---
# Do NOT reuse the same key for Finance and Reviewer: free tier is per project.

# Project B — news analysis at runtime (required by NestJS)
GEMINI_API_KEY_FINANCE=your_finance_gemini_api_key

# Project A — Reviewer Agent in GitHub Actions only (NOT required at NestJS boot)
# Configure as repo secret named GEMINI_API_KEY_REVIEWER when enabling automatic review:
#   Settings → Secrets and variables → Actions
# Also set variable AI_REVIEW_ENABLED=true to turn on .github/workflows/ai-review.yml
# (default / unset = off; use /rev in Cursor instead)
# GEMINI_API_KEY_REVIEWER=your_reviewer_gemini_api_key

# Delay between Gemini requests when analyzing news (milliseconds)
GEMINI_REQUEST_DELAY_MS=1000

# Gemini model for news analysis (default: gemini-3.5-flash).
# Prefer aliases like gemini-flash-latest if Google retires a versioned id.
# Avoid gemini-2.0-flash (shut down) and gemini-2.5-flash for new API keys.
GEMINI_MODEL=gemini-3.5-flash

# Telegram bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# RSS feeds — comma-separated list of 1-2 feed URLs (required)
RSS_FEED_URLS=https://example.com/finance/rss

# Cron expression for news collection (default: every 15 minutes)
COLLECTION_CRON_SCHEDULE=*/15 * * * *
